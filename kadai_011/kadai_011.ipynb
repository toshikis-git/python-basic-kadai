      "source": [
        "# 出力内容を定義\n",
        "array = [\"水\",\"金\",\"地\",\"火\",\"木\",\"土\",\"天\",\"海\",\"冥\"]\n",
        "\n",
        "# forループを用いた出力\n",
        "for item in array:\n",
        "    print(item)\n",
        "\n",
        "# whileループを用いた出力\n",
        "index = 0\n",
        "while index < len(array):\n",
        "    print(array[index])\n",
        "    index += 1"
      ]
    }
