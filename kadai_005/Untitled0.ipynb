      "source": [
        "\n",
        "#上辺：10cm\n",
        "upper_line = 10\n",
        "\n",
        "#下辺：20cm\n",
        "lower_line = 20\n",
        "\n",
        "#高さ：5cm\n",
        "height = 5\n",
        "\n",
        "#台形の面積格納用\n",
        "result = 0\n",
        "\n",
        "#台形の面積の計算（台形の面積 =（上辺＋下辺）× 高さ ÷ 2）\n",
        "result = (upper_line + lower_line) * height / 2\n",
        "\n",
        "#台形の面積を出力\n",
        "print(f\"{result}cm²\")\n",
        "\n"
      ]
    }
  ]
