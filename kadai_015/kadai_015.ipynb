      "source": [
        "class Human:\n",
        "    def __init__(self, name, age ):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    # メソッドを定義する\n",
        "    def printinfo(self):\n",
        "        print(f\"名前: {self.name}\")\n",
        "        print(f\"年齢: {self.age}\")\n",
        "\n",
        "# インスタンス化する\n",
        "user = Human(\"太郎\", 26)\n",
        "\n",
        "# メソッドにアクセスして実行する\n",
        "user.printinfo()\n"
      ]
    }
  ]
